{
  "identifier": "allmem-default",
  "description": "AllMem default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/.allmem" },
        { "path": "$HOME/.allmem/**" },
        { "path": "$HOME/.claude" },
        { "path": "$HOME/.claude/**" },
        { "path": "$HOME/.codex" },
        { "path": "$HOME/.codex/**" },
        { "path": "$HOME/.cursor" },
        { "path": "$HOME/.cursor/**" },
        { "path": "$HOME/AppData/Roaming/Cursor/User/workspaceStorage" },
        { "path": "$HOME/AppData/Roaming/Cursor/User/workspaceStorage/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/.allmem" },
        { "path": "$HOME/.allmem/**" },
        { "path": "$HOME/.claude" },
        { "path": "$HOME/.claude/**" },
        { "path": "$HOME/.codex" },
        { "path": "$HOME/.codex/**" },
        { "path": "$HOME/.cursor" },
        { "path": "$HOME/.cursor/**" },
        { "path": "$HOME/AppData/Roaming/Cursor/User/workspaceStorage" },
        { "path": "$HOME/AppData/Roaming/Cursor/User/workspaceStorage/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/.allmem/**" },
        { "path": "$HOME/.claude/**" },
        { "path": "$HOME/.codex/**" },
        { "path": "$HOME/.cursor/**" },
        { "path": "$HOME/AppData/Roaming/Cursor/User/workspaceStorage/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/.allmem/**" },
        { "path": "$HOME/.claude/**" },
        { "path": "$HOME/.codex/**" },
        { "path": "$HOME/.cursor/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/.allmem" },
        { "path": "$HOME/.allmem/**" },
        { "path": "$HOME/.claude" },
        { "path": "$HOME/.claude/**" },
        { "path": "$HOME/.codex" },
        { "path": "$HOME/.codex/**" },
        { "path": "$HOME/.cursor" },
        { "path": "$HOME/.cursor/**" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "$HOME/.allmem" },
        { "path": "$HOME/.allmem/**" },
        { "path": "$HOME/.claude" },
        { "path": "$HOME/.claude/**" },
        { "path": "$HOME/.codex" },
        { "path": "$HOME/.codex/**" },
        { "path": "$HOME/.cursor" },
        { "path": "$HOME/.cursor/**" },
        { "path": "$HOME/AppData/Roaming/Cursor/User/workspaceStorage" },
        { "path": "$HOME/AppData/Roaming/Cursor/User/workspaceStorage/**" },
        { "path": "D:/2026/**" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        { "path": "$HOME/.allmem/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME/.allmem/**" },
        { "path": "$HOME/.claude/**" },
        { "path": "$HOME/.codex/**" },
        { "path": "$HOME/.cursor/**" }
      ]
    },
    "shell:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "dialog:default",
    "store:default"
  ]
}
